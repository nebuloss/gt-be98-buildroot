config BR2_PACKAGE_GT_BE98_HOSTAPD
	bool "gt-be98-hostapd (hostapd_cli, vendor-source)"
	help
	  Builds hostapd_cli FROM the vendor GPL hostapd source (upstream
	  hostapd v2.10 + Broadcom patches, impl103). hostapd_cli is the
	  self-contained wpa_ctrl client (no driver / openssl / libnl / BRCM
	  glue) and is the clean-from-source proof for the hostapd tree.

	  The full hostapd DAEMON is NOT built here: its vendor brcm.config
	  (DRIVER_BRCM + MLO/MAP) is gated behind the Broadcom SDK header
	  graph (HND_SRC/SRCBASE) and links libceshared/libnl-3/openssl-1.1/
	  libnvram/libshared - i.e. the merlin SDK build environment. See the
	  package .mk and the RE wifi dossier for the daemon blocker detail.

	  Requires the firmware tree at
	  $(BR2_EXTERNAL)/../gt-be98-firmware (same dependency as the
	  production rootfs/bootfs recipes). Not wired into the production
	  image.

if BR2_PACKAGE_GT_BE98_HOSTAPD

config BR2_PACKAGE_GT_BE98_HOSTAPD_DAEMON
	bool "build the full hostapd daemon (DRIVER_BRCM, from source)"
	select BR2_PACKAGE_GT_BE98_LIBSHARED
	select BR2_PACKAGE_GT_BE98_NVRAM
	help
	  Also build the full hostapd DAEMON from source via the merlin
	  SDK build-glue (the vendor router target with brcm.config:
	  DRIVER_BRCM + NL80211 + MLO/MAP/SAE/OWE/HS20/WPS, TLS=openssl,
	  CEVENT). Links the from-source libshared + libnvram, the SDK
	  from-source openssl-1.1 + libnl, and the pinned closed
	  libceshared.so (KEEP-AS-GRAFT).

	  The resulting binary, stripped, is BYTE-IDENTICAL to the shipped
	  device hostapd (sha256 7453000858a8..., DT_NEEDED identical) -- a
	  reproducible-build match. Installs hostapd + its openssl-1.1 /
	  libnl / libceshared runtime deps into the rootfs.

config BR2_PACKAGE_GT_BE98_HOSTAPD_DAEMON_OPENSSL3
	bool "static-link openssl-3.6.2 into hostapd (close the EOL-1.1 gap)"
	depends on BR2_PACKAGE_GT_BE98_HOSTAPD_DAEMON
	select BR2_PACKAGE_GT_BE98_BR_OPENSSL
	help
	  Recompile + STATIC-link the hostapd daemon against openssl-3.6.2
	  (the gt-be98-br-openssl staging tree, libcrypto.a) instead of the
	  SDK's bundled, end-of-life openssl-1.1.1w. hostapd is the device's
	  SOLE live openssl-1.1 consumer, so this closes the EOL-1.1 gap.

	  No source edits: crypto_openssl.c already carries the openssl-3
	  #if-branches; the SAME source recompiles against the openssl-3
	  headers. The unused -lssl is dropped (hostapd imports 0 libssl
	  symbols; CONFIG_EAP is off). The result NEEDs NO libcrypto.so.1.1
	  / libssl.so.1.1 -- openssl-3 is baked in statically, so those
	  shared libs are NOT installed alongside hostapd in this mode.

	  WiFi-7 (MLO/320MHz, driver_nl80211.c) + SAE/WPA3 (sae.c) carry zero
	  openssl refs; all crypto is isolated in crypto_openssl.c. Operator
	  must runtime-trial: SAE/WPA3 + WiFi-7 association.

endif
