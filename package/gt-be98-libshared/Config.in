config BR2_PACKAGE_GT_BE98_LIBSHARED
	bool "gt-be98-libshared (libshared.so, from source)"
	help
	  Builds the asuswrt router/shared library (libshared.so) FROM
	  SOURCE via the merlin SDK build-glue (SRCBASE/HND_SRC + the
	  fully-expanded -DGTBE98 CFLAGS). 58 open .c compiled here; the
	  15 closed + 4 SDK-buildable prebuild/*.o linked as pinned graft
	  inputs. ABI-perfect vs the device libshared.so (1449/1449
	  exported symbols, 197/197 undefined, identical DT_NEEDED).

	  This is the from-source core that lets rc / hostapd link
	  -lshared without the prebuilt blob. Requires the firmware tree
	  at $(BR2_EXTERNAL)/../gt-be98-firmware. Not wired into the
	  production image.
