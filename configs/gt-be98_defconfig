# GT-BE98 Buildroot defconfig — Step 1: external toolchain + minimal rootfs.
#
# Arch/ABI below are CONFIRMED from the merlin cross-compiler (gcc -v on
# crosstools-arm_softfp-gcc-10.3): 32-bit ARM, cortex-a9, EABI soft-float ABI,
# VFPv3. Built against the latest stable Buildroot (2026.02.2); the external
# toolchain (gcc 10.3) is consumed as-is. NB gcc 10.3 lacks some GCC-11+ features,
# so a few modern upstream packages won't build (e.g. samba4 -> cmocka 2.0.2 uses
# __attribute__((access(none)))) — prefer ASUS blobs for those. Kernel/bootloader
# from source remain deferred (see ARCHITECTURE.md / AGENTS.md).
#
# Build with:
#   make BR2_EXTERNAL=/path/to/gt-be98-buildroot gt-be98_defconfig
#   make

# --- Target architecture (CONFIRMED) -----------------------------------------
BR2_arm=y
BR2_cortex_a9=y
BR2_ARM_EABI=y
# cortex-a9 has VFP only optionally (MAYBE_HAS_VFPV3), so VFP must be explicitly
# enabled before the VFPv3 FPU choice is selectable — otherwise Buildroot
# silently falls back to soft float, which is ABI-incompatible with the softfp
# sysroot. Toolchain is -mfloat-abi=softfp -mfpu=vfpv3.
BR2_ARM_ENABLE_VFP=y
BR2_ARM_FPU_VFPV3=y
# merlin compiles userspace+kernel with: -mcpu=cortex-a9 -marm
#   -march=armv7-a+mp+sec+vfpv3 -mfloat-abi=softfp -mfpu=vfpv3 -mabi=aapcs-linux
# (Userspace/rootfs is 32-bit ARM. NB the kernel itself is aarch64 — built
# separately with the aarch64 crosstool; that's Step 2b, not this target.)

# --- External toolchain (gt-be98-toolchain) ----------------------------------
# Versions confirmed from the compiler: gcc 10.3.0, binutils 2.36.1,
# glibc 2.32, kernel-headers 4.19. Tuple arm-buildroot-linux-gnueabi.
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_CUSTOM=y
#
# Toolchain SOURCE: download the single-variant tarball from its gt-be98-toolchain
# Release asset (built by scripts/make-buildroot-toolchain-tarball.sh). Verified
# end-to-end. For offline/local dev you can instead set BR2_TOOLCHAIN_EXTERNAL_PATH
# to a pre-extracted crosstools dir.
BR2_TOOLCHAIN_EXTERNAL_DOWNLOAD=y
BR2_TOOLCHAIN_EXTERNAL_URL="https://github.com/nebuloss/gt-be98-toolchain/releases/download/arm_softfp-gcc10.3/gt-be98-toolchain-arm_softfp-gcc10.3.tar.gz"
BR2_TOOLCHAIN_EXTERNAL_CUSTOM_PREFIX="arm-buildroot-linux-gnueabi"
BR2_TOOLCHAIN_EXTERNAL_GCC_10=y
BR2_TOOLCHAIN_EXTERNAL_HEADERS_4_19=y
BR2_TOOLCHAIN_EXTERNAL_CUSTOM_GLIBC=y
BR2_TOOLCHAIN_EXTERNAL_CXX=y
# This glibc 2.32 was built without the deprecated Sun RPC (removed from modern
# glibc); RPC support defaults on for glibc, so disable it or the toolchain check
# fails ("RPC support not available in C library").
# BR2_TOOLCHAIN_EXTERNAL_INET_RPC is not set

# --- Kernel (TODO — roadmap step 2) ------------------------------------------
# Broadcom 4.19 vendor kernel + BCM6813 dts/defconfig. Major task.

# --- Bootloader + image (roadmap step 2) -------------------------------------
# Step 2a: board/gt-be98/post-image.sh wraps the rootfs with a prebuilt bootfs
# .itb into a .pkgtb. mkimage comes from Buildroot's host-uboot-tools (the bundle
# is a plain FIT, so no Broadcom-specific mkimage is needed) — this removes the
# merlin-tree mkimage dependency; only the prebuilt bootfs .itb is still borrowed
# (-> gt-be98-packages blob). Step 2b will build the kernel/ATF/U-Boot from source.
BR2_PACKAGE_HOST_UBOOT_TOOLS=y
# FIT support is required: the bundle FIT carries sha256 hash nodes, which a
# non-FIT mkimage rejects (prints usage, exits 1).
BR2_PACKAGE_HOST_UBOOT_TOOLS_FIT_SUPPORT=y

# --- Root filesystem ---------------------------------------------------------
BR2_TARGET_ROOTFS_SQUASHFS=y
# merlin's rootfs.img is squashfs v4.0, xz, 128K block (the squashfs default),
# all-root (confirmed via `file`/mksquashfs args). Match the compressor:
BR2_TARGET_ROOTFS_SQUASHFS4_XZ=y

# --- Init / base userspace ---------------------------------------------------
BR2_INIT_BUSYBOX=y

# --- Userspace components (Step 4) -------------------------------------------
# Generic components that the merlin artifact ships and Buildroot has upstream
# (verify-artifact.sh checklist). The ASUS-specific ones (nvram, wl/dhd, httpd +
# web UI, rc/init, rtecdc.bin) become gt-be98-packages recipes/blobs separately.
BR2_PACKAGE_OPENSSL=y
BR2_PACKAGE_CJSON=y
BR2_PACKAGE_LIGHTTPD=y
BR2_PACKAGE_OPENVPN=y
BR2_PACKAGE_DROPBEAR=y
BR2_PACKAGE_STRONGSWAN=y
BR2_PACKAGE_STRONGSWAN_STROKE=y

# --- GT-BE98-specific components (Steps 3-4, gt-be98-packages blobs) ----------
# dhd wireless firmware (rtecdc.bin for radios 6717a0 + 6726b0).
BR2_PACKAGE_GT_BE98_DHD_FIRMWARE=y
# core asus userspace (nvram, rc, wl, dhd, httpd) + ASUS shared-lib closure.
BR2_PACKAGE_GT_BE98_USERSPACE_BASE=y
# The two below are built + verified but their Release assets aren't uploaded yet,
# so they're left OFF to keep a fresh-clone build self-contained/green. Uncomment
# once the gt-be98-packages samba-1.0 / bootfs-1.0 Release assets are published:
#   ASUS samba (smbd/nmbd) — upstream samba4 won't build on gcc 10.3.
# BR2_PACKAGE_GT_BE98_SAMBA=y
#   prebuilt bootfs .itb -> BINARIES_DIR (post-image bundles it; no merlin tree).
# BR2_PACKAGE_GT_BE98_BOOTFS=y

# --- Board hooks -------------------------------------------------------------
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_GT_BE98_PATH)/board/gt-be98/rootfs_overlay"
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_GT_BE98_PATH)/board/gt-be98/post-build.sh"
BR2_ROOTFS_POST_IMAGE_SCRIPT="$(BR2_EXTERNAL_GT_BE98_PATH)/board/gt-be98/post-image.sh"
