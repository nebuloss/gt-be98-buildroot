# Shared paths for the QEMU FullMAC RE harness. Source this from the scripts.
# Adjust if your checkout layout differs.

# Cross toolchain (gcc 10.3, matches the merlin 4.19.294 kernel)
TC=/home/guillaume/be98/gt-be98-firmware/toolchain/am-toolchains/brcm-arm-hnd/crosstools-aarch64-gcc-10.3-linux-4.19-glibc-2.32-binutils-2.36.1/bin
CROSS=$TC/aarch64-linux-

# QEMU built with the broadcom-fmac-stub device-model compiled in
QEMU=/home/guillaume/qemu-src/qemu-10.0.0/build/qemu-system-aarch64

# Stock vanilla 4.19.294 kernel, configured for -M virt (PCI_HOST_GENERIC + virtio)
STOCK_KSRC=/home/guillaume/qemu-src/linux-4.19.294
STOCK_IMAGE=$STOCK_KSRC/arch/arm64/boot/Image

# Merlin BCM6813 4.19.294 kernel (the ABI dhd.ko was built against). SoC-coupled:
# panics in bcm_ubus postcore_initcall under -M virt, and lacks PCI_HOST_GENERIC.
MERLIN_IMAGE=/home/guillaume/be98/gt-be98-firmware/vendor/asuswrt-merlin.ng/release/src-rt-5.04behnd.4916/kernel/linux-4.19/arch/arm64/boot/Image

# CP-1 HARNESS kernel: merlin 4.19.294 source + PCI_HOST_GENERIC/VIRTIO + the
# bcm_ubus QEMU-harness stub + FTRACE/KPROBES/KGDB/DYNAMIC_DEBUG. Boots under
# -M virt AND exports the 70 merlin-only vmlinux symbols dhd's dep chain needs.
# Built by qemu-harness/harness-kernel/build-harness-kernel.sh; committed Image.
HARNESS_IMAGE=$(cd "$(dirname "$0")/.." && pwd)/harness-kernel/Image
# gdb symbols for the harness vmlinux (not committed; rebuild to regenerate)
HARNESS_VMLINUX=/home/guillaume/be98/job-tmp/cp1-harness/vmlinux.harness

# Closed FullMAC driver + deps + firmware
MODDIR=/home/guillaume/.claude/jobs/5eb9adaf/tmp/base-rootfs/lib/modules/4.19.294/extra
DHD_KO=$MODDIR/dhd.ko
FW_6717=/home/guillaume/.claude/jobs/5eb9adaf/tmp/base-rootfs/rom/etc/wlan/dhd/6717a0/release/rtecdc.bin

# Harness dir (resolved relative to this file so it follows the checkout)
HARNESS=$(cd "$(dirname "$0")/.." && pwd)
