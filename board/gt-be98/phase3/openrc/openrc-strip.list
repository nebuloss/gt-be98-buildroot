# openrc-strip.list — v25 SLIM open-init strip manifest
#
# Paths (rootfs-relative, NO leading slash) removed by openrc-assemble.sh from
# the unsquashed $FS BEFORE mksquashfs. Lines beginning with # and blank lines
# are ignored. `rm -rf` is tolerant of already-absent paths.
#
# Every path below was resolved against the br-0050 base-rootfs reference
# (/home/guillaume/.claude/jobs/5eb9adaf/tmp/base-rootfs) and ONLY listed if it
# EXISTS there. Each "verify-only-used-by" library was confirmed via a full
# DT_NEEDED reverse-dependency scan of the entire rootfs (needed-map.txt).
#
# DO-NOT-REMOVE invariant (must never appear here): libbwdpi.so libbwdpi_sql.so
# libsqlite3.so* libovpn.so libssl.so.1.1 libcrypto.so.1.1 /lib/modules/*/extra
# cfg80211.ko wl hostapd* nvram eapd wlceventd mcpd acsd2 wlconf ethswctl vlanctl
# fc/fcctl bcm_boot_launcher rc /rom/etc/rc3.d dropbearmulti sftp-server
# openrc-init* OpenRC libs.

# --- /usr/br staging cruft (~5.97MB xz) -------------------------------------
# KEPT (NOT listed): usr/br/sbin/dropbearmulti, usr/br/libexec/sftp-server,
#                    usr/br/bin/scp, usr/br/bin/sftp  (the SSH/SFTP channel)
usr/br/bin/openssl
usr/br/bin/ssh
usr/br/bin/ssh-keygen
usr/br/bin/busybox

# --- samba (~2.74MB) --------------------------------------------------------
# NOTE: libsmbclient.so* surviving referrer after this strip is liblightsql.so,
# whose only consumers (mod_aicloud_auth/aidisk_access/smbdav/webdav) are ALL
# removed below, so liblightsql is orphaned and the dangling dep is inert.
usr/sbin/samba_multicall
usr/lib/libsmbclient.so
usr/lib/libsmbclient.so.0
usr/sbin/sambaclient
sbin/write_smb_conf

# --- Tor (~1.07MB) ----------------------------------------------------------
usr/sbin/Tor

# --- ookla (~0.73MB) --------------------------------------------------------
usr/sbin/ookla

# --- VPN (~0.9MB+) ----------------------------------------------------------
