#!/sbin/openrc-run
# === v22 ★COMMITTABLE BASELINE★ — default route + admin user + clean committed boot =
# v21 PROVED the open-init is externally reachable with a root shell (the DEFAULT ROUTE
# below was the fix). v22 makes it a committable baseline: (1) the new watchdog-disarm
# service (default runlevel, last) does `wdtctl stop` ONLY on a COMMITTED boot (no
# /data/.trial-armed) so the committed open-init does NOT reboot-loop every 240s — on a
# TRIAL it stays armed for the revert safety + manual SSH disarm; (2) assemble bakes an
# `admin` user (so admin@:2222 works like br-0045, not just root@); (3) the debug cruft
# (:2230 -E log, net-diag, syn_probe) is gated to TRIAL-only so committed boots stay
# clean. The default-route fix + datapath + :2222/:2223 are KEPT.
# === v21 ★THE FIX: add the DEFAULT ROUTE (cross-subnet return path)★ ============
# v20 was decisive: inbound SYN reaches the L3 INPUT hook (87) but never dropbear (0
# SYN_RECV / 0 conntrack / dropbear -E log empty / 0 SYN-ACK), AND `ip route get
# 10.0.50.177` returned NOTHING — the open-init had NO DEFAULT ROUTE (net-lan set the
# br0 IP but not the gateway). My build host is on a different subnet, so the SYN-ACK
# return path needs the default gw; without it the bcm stack drops the inbound SYN
# before the socket. v21 adds `default via <nvram lan_gateway> dev br0` (as rc does).
# Keeps the v20 instrumentation so the same logs confirm the fix (expect SYN_RECV +
# OUTPUT SYN-ACK>0 + dropbear "Child connection" + my catcher banner). No auto-disarm.
# === v20 ★SYN reaches INPUT but not the socket★ ================================
# v19 surprise: the firewall was ALREADY fully open (-P INPUT ACCEPT, 0 rules). So the
# SYN traverses the INPUT netfilter hook (counted 87) yet never reaches dropbear (0
# SYN_RECV) and isn't firewalled. Something between the INPUT hook and the listening
# socket consumes it — bridge-netfilter (br0 not delivering its own MAC to L3) or the
# bcm blog/fcache accelerator. v20 instruments to localize it: (a) :2230 dropbear runs
# -E -F -> /data/dropbear-2230.log (did the SYN reach dropbear?); (b) an OUTPUT --sport
# 2230 counter (did dropbear send a SYN-ACK? => return-path, not delivery); (c) a one-
# time bridge-nf/FDB/return-route dump; (d) syn_probe also samples OUTPUT + conntrack.
# === v19 ★firewall was already open★ ==========================================
# v18 layered counters were DECISIVE: raw/PREROUTING :2230 = 87 pkts AND INPUT :2230 =
# 87 pkts, but dropbear saw 0 SYN_RECV -> the inbound SYN reaches the CPU + the local
# INPUT chain and is then DROPPED by a firewall rule/policy the graft leaves in place
# for NEW inbound. NOT a Broadcom runner issue (v14-v17 chased the wrong layer). v19
# records the original firewall to /data/firewall.log, then sets ACCEPT policy + flushes
# INPUT so NEW inbound reaches the sockets. Keeps the :2230 slot-proof + layered counters
# (now expect INPUT count == reaches-dropbear == SYN_RECV) + SYN-probe. No auto-disarm.
# === v18 ★LAYERED SYN COUNTERS★ ===============================================
# v17 VOPI did NOT fix inbound (still 0 SYN_RECV). v18 reverts to raw eth bridging
# (br-0050-faithful) and adds iptables count-only rules at the two earliest CPU hooks
# for dport 2230 (raw/PREROUTING + INPUT), sampled by syn_probe. Only MY external SYNs
# hit :2230, so the counts are clean: raw/PREROUTING==0 => SYN never reaches the CPU
# (runner/switch drop, the hard Broadcom part); raw>0 & INPUT==0 => CPU got it but
# routing didn't deliver locally (Linux-fixable); both>0 => reaches dropbear (return
# path). Auto-disarm REMOVED (operator: disarm only from a confirmed SSH session).
# === v17 ★RUNNER-REGISTERED VOPI br0★ (reverted in v18) ========================
# v16 SYN-probe was DEFINITIVE: 66 netstat samples, ZERO SYN_RECV for :2230 -> the
# external unicast SYN to br0's IP NEVER reaches the CPU (runner flow-miss punt fail).
# v17 bridges a vlanctl untagged VOPI (ethN.v0) into br0 instead of raw ethN, so the
# bcm runner is REGISTERED to deliver that ingress to the CPU (the exact mechanism the
# open-init's working br20-70 use; init-broadcom.c:12221). Keeps fc enable + rtpolicy +
# the :2230 slot-proof + the SYN-probe (so SYN_RECV/ESTABLISHED now confirms the fix) +
# the auto-disarm watcher (stays on slot2 the moment inbound works, no login needed).
# === v16 ★SYN-PROBE DIAGNOSTIC★ ================================================
# v15 net-diag /proc/net/dev showed br0 RX 60 pkts/3192 B (25 mcast) -> inbound L2
# DOES reach the CPU; and v15's ethswctl hw-switching disable FAILED (rc=95, no-op).
# So the question narrows: does my UNICAST SYN to :2230 reach dropbear? v16 keeps the
# faithful datapath (fc enable + rtpolicy) and adds syn_probe() -> /data/syn-probe.log
# (full `netstat -tn` for :2230 every 3s): SYN_RECV = SYN reached CPU but handshake
# didn't complete (RETURN-PATH issue); ESTABLISHED = full inbound works; only-LISTEN =
# SYN never reached CPU (runner punt issue). Also fixes the v15 watcher `seq` bug
# (busybox.openrc has no seq -> the loop never ran) by using a while-counter.
# === v15 ★SOFTWARE-BRIDGE DATAPATH + AUTO-DISARM-ON-INBOUND★ ===================
# v14 RESULT (DEFINITIVE, via the unique :2230 port): the open-init boots, br0 up,
# :2222/:2223/:80/:2230 all LISTENING, OUTBOUND works (ping gateway PASS), but a
# brand-new EXTERNAL SYN to :2230 is NEVER punted to the CPU -> INBOUND is broken at
# the bcm runner (flow-miss not delivered to the CPU for the plain-brctl br0). v15:
# (1) DATAPATH -> software bridge: `ethswctl -c hw-switching -o disable` + `fc disable`
#     (skip rtpolicy) so the HW switch sends ALL frames to the CPU and the kernel
#     bridge forwards in software -> every inbound packet reaches the CPU.
# (2) AUTO-DISARM-ON-INBOUND: a watcher stops the watchdog the moment a real external
#     connection reaches :2230/:2222/:80 -> proves inbound + keeps slot2 alive WITHOUT
#     needing dropbear login auth (the auth question stays separate). See start().
# === v14 ★UNAMBIGUOUS INBOUND/SLOT PROOF (:2230)★ ==============================
# The v2..v13 "unreachable" was never slot-disambiguated (every probed port also
# exists on br-0045/br-0050, so a catcher couldn't tell the open-init from br-0045
# after the auto-revert). v14 changes ONLY the MEASUREMENT: it launches a dropbear on
# the UNIQUE port :2230 (opened by NOTHING but this open-init). `nc 10.0.0.8 2230`
# returning the SSH banner == INBOUND WORKS on slot2 (no auth needed); `ssh -p 2230`
# logging in == AUTH works. Datapath (fc enable + rtpolicy + allmulti) is IDENTICAL to
# v13, so the :2230 result is a clean read on whether v13 already had inbound. See the
# :2230 block in start(). If :2230 banner is UNREACHABLE (but net-diag self-test PASS),
# inbound is genuinely broken with fc-enable -> v15 tries fc-disable (software bridge).
# === v13 ★ADMIN-KEY BYTE-MATCH + FIXED AUTH INSTRUMENT★ on top of v12 ===========
# v12 RESULT: :2222 LISTENING, perms EXACTLY br-0045's (700/700/600 uid0:gid0),
# datapath PASS, :80 reachable — but admin key STILL rejected. Two gaps closed in
# v13: (a) the authorized_keys CONTENT did NOT byte-match br-0045 — v12 wrote it
# from `nvram get sshd_authkeys` (263 B, sha 01d03d09, mangled internal LFs) which
# differs from the 262 B / sha 6a09e22c on-disk key file; v13 instead copies the
# AUTHORITATIVE /jffs/.ssh/authorized_keys (byte-identical to br-0045) and VERIFIES
# sha/byte-count, logging RESULT: PASS/FAIL to /data/net-diag.log (counts/sha only).
# (b) the v12 debug dropbear used `-E -F -v`, but -v is INVALID on dropbear v2025.88
# (prints usage + exits, :2229 never bound, no verdict captured); v13 launches
# `dropbear -E -F -p 2229` so the pubkey-auth verdict lands in /data/dropbear-auth.log.
# --- v12 history (perms fix, kept) ---
# v11 RESULT: open-init boots, datapath PASS, :80/:2222/:2223 serving, admin key
# WRITTEN to ~/.ssh/authorized_keys — but dropbear v2025.88 REJECTED the admin key.
# ROOT CAUSE (dropbear src svr-authpubkey.c checkpubkeyperms()/checkfileperm() +
# br-0045 perms captured READ-ONLY): dropbear walks the auth path UP from
# authorized_keys to pw_dir(/root) and refuses any node that is group/other-writable
# or not owned by the user/root. Under the open-init's umask 0000 every `mkdir -p`
# made the .ssh dirs mode 0777 -> rejected. v12 FIX: explicit chown 0:0 + chmod
# 700/700/600 on the whole walked chain (homedir -> .ssh -> authorized_keys),
# EXACTLY matching br-0045 (drwx------ /tmp/home/root, drwx------ .ssh, -rw-------
# authorized_keys, all uid0:gid0). Plus v12 instrumentation: dump the chain perms to
# /data/net-diag.log + a verbose `-E -F -v` debug dropbear on :2229 logging the exact
# auth verdict to /data/dropbear-auth.log. Everything from v11 (:2222 + :2223 +
# datapath) is KEPT.
# === v8 ★REACHABILITY+DATAPATH★: wired LAN + Broadcom runner datapath + sshd ====
# v7 RESULT: open-init booted fully (OpenRC sysinit->boot->default), net-lan did
# config_switch + config_extwan + brctl addbr br0 + ip addr 10.0.0.8 (all [ok]),
# but NO traffic passed -> never reachable on slot2. On Broadcom, br0 + ip is NOT
# enough: the HW flow-accelerator/runner datapath (eth port <-> bridge <-> CPU)
# must be configured, which the ASUS rc START state does AFTER the bridge is up.
#
# v8 DATAPATH DIAGNOSIS (live br-0045 capture + rc source, sw_mode=3 AP/bridge):
#   The runner modules (pktrunner, bcm_enet, pktflow, cmdlist, rdpa*, bdmf) are
#   already loaded by bcm_boot_launcher (bcm-platform). The eth<->bridge<->CPU
#   datapath needs THREE steps beyond brctl/ip, all confirmed on the live device:
#   (a) ★ALLMULTI on br0 + every bridge member★ — rc start_lan brings the bridge
#       up via ifconfig(lan_ifname, IFUP|IFF_ALLMULTI, ...) and members are
#       ALLMULTI too (ifconfig br0/eth0 -> "UP BROADCAST RUNNING ALLMULTI"). The
#       bcm_enet+runner datapath floods/forwards to the CPU port via ALLMULTI;
#       v7 used `ip link set up` (NO ALLMULTI) -> the runner never bridged to CPU.
#   (b) ★fc enable★ — rc start_lan's fc_init() runs `fc enable` (flow-cache HW
#       accelerator) when !is_routing_enabled() (sw_mode=3 here). Live device:
#       `fcctl status` -> "HW Acceleration <Enabled>", fc_disable=0.
#   (c) ★rtpolicy auto ALL★ — rc init_main START state (init.c:26613, the
#       RTCONFIG_HND_ROUTER_BE_4916 step right after start_lan) runs
#       `rtpolicy auto ALL` -> applies the runner runtime policy from
#       /etc/rt_policy_info.d/. runner_disable=0.
#
# Open-path bring-up:
#   1. `rc config_switch` + `rc config_extwan` — standalone in-proc rc applets
#      (rc.c:4388/4394) that program the CLOSED Broadcom HW switch via the
#      ethswctl/vlanctl ABI. They do NOT signal PID1 -> work under OpenRC [V-src].
#   2. open start_lan stand-in: `brctl addbr br0` + add lan_ifnames members +
#      members UP with ALLMULTI + `ifconfig br0 ... IFF_ALLMULTI <ip> <nm>`, all
#      from nvram (lan_ifnames / lan_ipaddr / lan_netmask; nvram is up).
#   3. ★v8 datapath★: `fc enable` (flow cache) + `rtpolicy auto ALL` (runner) so
#      eth <-> br0 <-> CPU actually passes traffic -> SSH reachable.
#   4. sshd reachability: relaunch the :2223 RESCUE (dropbearmulti, /data hostkey;
#      replicates br-dropbear.sh — defensive, in case rc3.d ordering differs) and
#      ★v10★ the merlin admin :2222 as a FAITHFUL replica of br-0045: /etc/dropbear
#      hostkeys symlinked -> /jffs/.ssh/dropbear_*_host_key, admin authorized_keys
#      from `nvram get sshd_authkeys` -> $HOME/.ssh/authorized_keys, EXACT cmdline
#      `dropbear -p 2222 -j -k`. v9 PROVED the datapath (gateway ping PASS, :80 +
#      :2223 listening) but :2222 used a keyless /data-hostkey dropbear that never
#      bound (default /etc/dropbear hostkeys absent under the open-init's /etc
#      tmpfs); v10 sets up exactly the paths the merlin dropbear reads.
# Ordered AFTER bcm-platform (drivers + nvram loaded), BEFORE the rest.
description="GT-BE98 wired LAN + Broadcom runner datapath + sshd (open-init reachable, :2222 merlin admin)"

depend() {
	need nvram
	after bcm-platform
	before wifi-radio webui
	provide net
}

blog() { echo "$(cat /proc/uptime) net-lan: $*" >> /data/openrc-boot.log 2>/dev/null; }

# netmask dotted-quad -> CIDR prefix length (fallback 24).
nm2cidr() {
	local nm="$1" b n=0
	case "$nm" in *.*.*.*) ;; *) echo 24; return;; esac
	local IFS=.
	for b in $nm; do
		while [ "$b" -gt 0 ] 2>/dev/null; do n=$((n + (b & 1))); b=$((b >> 1)); done
	done
	[ "$n" -ge 1 ] && [ "$n" -le 32 ] && echo "$n" || echo 24
}

# Launch a dropbear listener on $1, binary $2, with a /data-persisted ed25519
# hostkey (stable fingerprint across boots/slots — same as br-dropbear.sh). A
# capped babysitter loop respawns it (OpenRC does not supervise it). Skip if the
# port is already bound (e.g. :2223 already up via rc3.d S28br-dropbear).
KEYDIR=/data/br/dropbear
start_dropbear() {
	local port="$1" dbin="$2" pidf="/tmp/dropbear-${port}.pid"
	[ -x "$dbin" ] || { blog "dropbear bin $dbin missing -> skip :$port"; return; }
	if netstat -ltn 2>/dev/null | grep -q ":${port} "; then
		blog "port :$port already listening -> not relaunching"
		return
	fi
	mkdir -p "$KEYDIR" 2>/dev/null
	[ -f "$KEYDIR/hostkey" ] || "$dbin" dropbearkey -t ed25519 -f "$KEYDIR/hostkey" >/dev/null 2>&1
	(
		N=0
		while [ "$N" -lt 20 ]; do
			"$dbin" dropbear -F -r "$KEYDIR/hostkey" -p "$port" -P "$pidf" >/dev/null 2>&1
			N=$((N + 1))
			sleep 5
		done
	) &
	blog "launched dropbear on :$port ($dbin, /data hostkey)"
}

# === v10 ★ADMIN :2222★ — faithful replica of the br-0045 merlin :2222 dropbear ==
# v9 RESULT (net-diag.log): datapath PASSED (gateway ping 0% loss), :80 + :2223
# LISTENING — but :2222 admin sshd did NOT bind. ROOT CAUSE: v9 launched :2222 via
# start_dropbear (a /data ed25519-hostkey dropbear with NO authorized_keys), and on
# the merlin /usr/sbin/dropbear (-> dropbearmulti) the DEFAULT hostkey dir is
# /etc/dropbear/dropbear_{ecdsa,ed25519,rsa}_host_key — which, under the open-init,
# is an /etc tmpfs symlink-farm to RO /rom/etc (no dropbear dir) so the hostkeys are
# absent and dropbear exits before binding. The admin pubkey (nvram sshd_authkeys)
# was also never written to where dropbear reads it.
#
# EXACT br-0045 (READ-ONLY captured) merlin :2222 setup this replicates:
#   * cmdline:  `dropbear -p 2222 -j -k`   (-j/-k = disable local/remote fwd; NO -r,
#                so it uses the DEFAULT /etc/dropbear/dropbear_*_host_key hostkeys).
#   * hostkeys: /etc/dropbear/dropbear_{ecdsa,ed25519,rsa}_host_key are SYMLINKS to
#               /jffs/.ssh/dropbear_*_host_key (persist on /jffs, shared across
#               slots; all 3 confirmed present on the live device — ls, not cat).
#   * authkeys: `nvram get sshd_authkeys` is written to $HOME/.ssh/authorized_keys.
#               admin HOME=/root (-> /tmp/home/root tmpfs); a persistent copy also
#               lives at /jffs/.ssh/authorized_keys (262 B, identical). dropbear with
#               -j -k (no -A/-U) reads ~/.ssh/authorized_keys for the connecting user
#               -> /root/.ssh/authorized_keys.
# We set up exactly those paths, then launch the EXACT merlin cmdline. Hardened so a
# missing key / dropbear hang can NEVER wedge boot (all guarded + babysitter capped).
JFFS_SSH=/jffs/.ssh
start_admin_dropbear() {
	local dbin=/usr/sbin/dropbear pidf=/tmp/dropbear-2222.pid k
	[ -x "$dbin" ] || { blog "admin dropbear bin $dbin missing -> skip :2222"; return; }
	if netstat -ltn 2>/dev/null | grep -q ":2222 "; then
		blog "port :2222 already listening -> not relaunching admin sshd"
		return
	fi

	# (a) /etc/dropbear must be a REAL writable dir, not the etc-farm symlink into
	#     RO /rom/etc. Replace any symlink, then symlink the 3 hostkeys -> /jffs/.ssh
	#     (the persistent, slot-shared keys — same layout as br-0045).
	[ -L /etc/dropbear ] && rm -f /etc/dropbear 2>/dev/null
	mkdir -p /etc/dropbear 2>/dev/null
	for k in ecdsa ed25519 rsa; do
		if [ -f "$JFFS_SSH/dropbear_${k}_host_key" ]; then
			ln -sf "$JFFS_SSH/dropbear_${k}_host_key" \
				"/etc/dropbear/dropbear_${k}_host_key" 2>/dev/null
		else
			blog "admin :2222 WARN: $JFFS_SSH/dropbear_${k}_host_key absent"
		fi
	done

	# (b) admin authorized_keys: nvram sshd_authkeys -> $HOME/.ssh/authorized_keys
	#     ★v11 THE ONE FIX★ — v10 got :2222 LISTENING but logged
	#       `can't create /root/.ssh/authorized_keys: nonexistent directory`
	#     so NO admin key was loaded -> auth rejected. ROOT CAUSE (confirmed READ-ONLY
	#     on br-0045 — /etc/passwd `admin:x:0:0:admin:/root:/bin/sh`, HOME=/root, and
	#     `/root` is a SYMLINK -> tmp/home/root on tmpfs): under the open-init the
	#     symlink TARGET /tmp/home/root does NOT exist (etc-farm makes /tmp/home but
	#     NOT /tmp/home/root), so `/root` is a DANGLING symlink and `mkdir -p
	#     /root/.ssh` refuses to create through it -> "nonexistent directory".
	#     FIX: resolve where $HOME/.ssh actually lands and create the REAL target
	#     dir first (mkdir -p the symlink target, e.g. /tmp/home/root), THEN
	#     mkdir -p /root/.ssh AND "$HOME/.ssh", write the key to BOTH resolved paths
	#     (+ keep the persistent /jffs/.ssh/authorized_keys), chmod 700/600. Never
	#     log key content.
	# ★v12 THE ONE FIX★ — v11 wrote the admin key to $HOME/.ssh/authorized_keys and
	# :2222 LISTENED, but dropbear v2025.88 REJECTED the admin key. ROOT CAUSE (read
	# from dropbear src svr-authpubkey.c checkpubkeyperms()/checkfileperm() + the live
	# br-0045 perms captured READ-ONLY): dropbear walks the auth path UP from
	# authorized_keys to the user's homedir (pw_dir=/root) and DEMANDS that EACH of
	#   ~/.ssh/authorized_keys , ~/.ssh , ~  (=/root -> /tmp/home/root)
	# is (a) owned by the user or root (uid 0) AND (b) NOT group/other-writable
	# (st_mode & (S_IWGRP|S_IWOTH) == 0). The open-init runs with umask 0000, so every
	# bare `mkdir -p` here created the dir mode 0777 = group+other writable -> dropbear
	# refused it with "must be owned by user or root, and not writable by group or
	# others" -> admin key REJECTED. (etc-farm chmod 700 /tmp/home/root, but the .ssh
	# dirs net-lan created stayed 0777 under umask 0000.)
	# FIX: set the EXACT br-0045 working perms+ownership on the whole walked chain —
	#   /tmp/home/root      drwx------ (700) uid0:gid0   (= homedir = dropbear walk top)
	#   /tmp/home/root/.ssh drwx------ (700) uid0:gid0
	#   .../authorized_keys -rw------- (600) uid0:gid0   (262 B on br-0045)
	# with EXPLICIT chmod + chown 0:0 (never rely on umask). /tmp (1777) and /tmp/home
	# (755) are ABOVE pw_dir so dropbear does NOT walk into them (the walk stops at
	# pw_dir), matching why br-0045's world-writable /tmp is fine — we leave them.
	local home="${HOME:-/root}" ak akdir tgt
	# If $home is a symlink (merlin: /root -> /tmp/home/root), ensure its target
	# directory exists so mkdir -p / writes through the link succeed. Resolve the
	# link target (absolute), create it, and also force-create /root's target.
	if [ -L "$home" ]; then
		tgt=$(readlink -f "$home" 2>/dev/null)
		[ -n "$tgt" ] && mkdir -p "$tgt" 2>/dev/null && blog "admin: created HOME symlink target $tgt (for $home)"
	fi
	if [ -L /root ]; then
		tgt=$(readlink -f /root 2>/dev/null)
		[ -n "$tgt" ] && mkdir -p "$tgt" 2>/dev/null
	fi
	# Now the .ssh dirs can be created (through the now-valid symlinks too).
	mkdir -p /root/.ssh 2>/dev/null
	akdir="$home/.ssh"; ak="$akdir/authorized_keys"
	mkdir -p "$akdir" 2>/dev/null
	# ★v12★ Lock the EXACT br-0045 perms+ownership on EVERY node dropbear walks
	# (homedir -> .ssh -> authorized_keys). chown 0:0 + chmod explicitly so umask
	# 0000 can never leave them group/other-writable. Apply to BOTH the symlink
	# names (/root, $HOME) AND the resolved real target (/tmp/home/root) so whichever
	# path dropbear stat()s sees 700/600 uid0:gid0. (chown follows symlinks; harmless.)
	# homedir: /root, $HOME, and the resolved tmpfs target — all -> 700 uid0:gid0
	for d in /root "$home" "$(readlink -f /root 2>/dev/null)"; do
		[ -n "$d" ] && [ -d "$d" ] && { chown 0:0 "$d" 2>/dev/null; chmod 700 "$d" 2>/dev/null; }
	done
	# .ssh dirs -> 700 uid0:gid0
	for d in /root/.ssh "$akdir"; do
		[ -d "$d" ] && { chown 0:0 "$d" 2>/dev/null; chmod 700 "$d" 2>/dev/null; }
	done
	# ★v13 THE ONE FIX — BYTE-MATCH br-0045's authorized_keys★
	# v12 got :2222 LISTENING + perms EXACTLY br-0045's (700/700/600 uid0:gid0) +
	# datapath PASS, but the admin key was STILL rejected. ROOT CAUSE (diagnosed by
	# READing br-0045 READ-ONLY): v12 wrote the key from `nvram get sshd_authkeys`
	# piped through `printf '%s\n'`, which does NOT byte-match the on-disk key file:
	#   * br-0045 /tmp/home/root/.ssh/authorized_keys : 262 B, 2 LF (offsets 80,161),
	#         sha256 6a09e22ceb71274f6b680b5037202f6d69d0b591edcfc4c5127362ee187d6364
	#   * raw `nvram get sshd_authkeys`               : 263 B, 1 LF (trailing only),
	#         sha256 01d03d09... — DIFFERENT bytes (nvram mangles the internal LFs:
	#         even strip-trailing-LF gives 262 B but sha d319f33d + 3 LFs, first byte
	#         diff at char 81 = the file's first LF). So nvram CANNOT byte-reproduce
	#         the file -> dropbear saw a key string that didn't match -> reject.
	# FIX: prefer the AUTHORITATIVE source — /jffs/.ssh/authorized_keys, which on
	# br-0045 is BYTE-IDENTICAL to the live ~/.ssh/authorized_keys (same sha 6a09e22c,
	# 262 B, 2 lines; it is the slot-shared source of truth dropbear -j -k reads).
	# Only if /jffs is ABSENT do we fall back to nvram (normalized: tr -d '\r',
	# ensure exactly one trailing LF) — best-effort, may not byte-match but is the
	# last resort. After writing, we VERIFY sha/byte-count vs br-0045's target and
	# log RESULT: PASS/FAIL (counts/sha ONLY, key bytes NEVER printed).
	local nk; nk=$(nvram get sshd_authkeys 2>/dev/null)
	local AK_BR0045_SHA=6a09e22ceb71274f6b680b5037202f6d69d0b591edcfc4c5127362ee187d6364
	local AK_BR0045_BYTES=262
	local f wrote=0 src=none
	for f in "$ak" /root/.ssh/authorized_keys; do
		[ -d "${f%/*}" ] || continue
		if [ -f "$JFFS_SSH/authorized_keys" ]; then
			# AUTHORITATIVE: byte-identical to br-0045 -> exact copy, no transform.
			cp "$JFFS_SSH/authorized_keys" "$f" 2>/dev/null && { chown 0:0 "$f" 2>/dev/null; chmod 600 "$f" 2>/dev/null; wrote=1; src=jffs; }
		elif [ -n "$nk" ]; then
			# FALLBACK: nvram. Strip CR drift, guarantee exactly one trailing LF.
			# (printf '%s\n' on a value already ending in \n would add nothing here
			# because we strip first; best-effort — may not byte-match br-0045.)
			printf '%s\n' "$(nvram get sshd_authkeys 2>/dev/null | tr -d '\r')" > "$f" 2>/dev/null \
				&& { chown 0:0 "$f" 2>/dev/null; chmod 600 "$f" 2>/dev/null; wrote=1; src=nvram; }
		fi
	done
	if [ "$wrote" = 1 ]; then
		blog "admin authkeys -> $ak (+/root/.ssh) [src=$src]"
	else
		blog "admin :2222 WARN: no $JFFS_SSH/authorized_keys + no sshd_authkeys nvram (key-auth will reject)"
	fi
	# Keep the persistent /jffs copy as the source of truth; only seed it from nvram
	# (normalized) if it is entirely ABSENT (cannot byte-match br-0045 in that case).
	[ -d "$JFFS_SSH" ] && [ -n "$nk" ] && [ ! -f "$JFFS_SSH/authorized_keys" ] && \
		{ printf '%s\n' "$(nvram get sshd_authkeys 2>/dev/null | tr -d '\r')" > "$JFFS_SSH/authorized_keys" 2>/dev/null && chmod 600 "$JFFS_SSH/authorized_keys" 2>/dev/null; }
	# ★v13 BYTE-MATCH VERIFY★ — compare what we wrote to br-0045's known sha/bytes
	# and log a definitive RESULT line (sha/counts ONLY, NEVER key content).
	{
		mine_bytes=$(wc -c < "$ak" 2>/dev/null)
		mine_sha=$(sha256sum "$ak" 2>/dev/null | cut -d' ' -f1)
		if [ "$mine_sha" = "$AK_BR0045_SHA" ] && [ "$mine_bytes" = "$AK_BR0045_BYTES" ]; then
			echo "RESULT: PASS authkeys byte-match (mine=${mine_bytes}B sha=${mine_sha:-none} br0045=${AK_BR0045_BYTES}B sha=${AK_BR0045_SHA}) [src=$src]"
		else
			echo "RESULT: FAIL authkeys byte-match (mine=${mine_bytes:-0}B sha=${mine_sha:-none} br0045=${AK_BR0045_BYTES}B sha=${AK_BR0045_SHA}) [src=$src]"
		fi
	} >> "$DIAG" 2>/dev/null

	# ★v12 INSTRUMENT (a)★ — dump the EXACT perms+ownership of the walked auth chain
	# to PERSISTENT /data/net-diag.log so the next trial is DEFINITIVE about whether
	# the chmod/chown above produced the br-0045-identical 700/700/600 uid0:gid0.
	# PRIVACY: ls -la shows only mode/owner/size/name — NEVER the key BYTES. We log
	# the authorized_keys LINE COUNT + SIZE only (no content). MACs N/A here.
	{
		echo "================================================================"
		echo "v13 ADMIN :2222 AUTH-CHAIN PERMS (target: br-0045 = 700/700/600 uid0:gid0)"
		echo "uptime: $(cat /proc/uptime 2>/dev/null)"
		echo "HOME=$home  pw_dir(/root)->$(readlink -f /root 2>/dev/null)"
		echo "----- ls -lad walked chain (homedir -> .ssh) -----"
		ls -lad /tmp /tmp/home /tmp/home/root /tmp/home/root/.ssh /root /root/.ssh 2>&1
		echo "----- authorized_keys (perms/owner/SIZE only; content NEVER printed) -----"
		ls -la /tmp/home/root/.ssh/authorized_keys "$ak" 2>&1
		if [ -f "$ak" ]; then
			echo "authorized_keys: $(wc -c < "$ak" 2>/dev/null) bytes, $(wc -l < "$ak" 2>/dev/null) line(s) [content redacted]"
		fi
		echo
	} >> "$DIAG" 2>/dev/null

	# (c) launch the EXACT br-0045 merlin cmdline: `dropbear -p 2222 -j -k` (default
	#     /etc/dropbear hostkeys, -j/-k disable port forwarding). NOT -F: merlin runs
	#     it as a self-backgrounding daemon (it forks + writes the lease itself). A
	#     capped babysitter respawns it if it dies (OpenRC does not supervise it),
	#     and it ONLY relaunches while :2222 is unbound so we never pile up daemons.
	(
		N=0
		while [ "$N" -lt 20 ]; do
			netstat -ltn 2>/dev/null | grep -q ":2222 " && break
			"$dbin" -p 2222 -j -k -P "$pidf" >/dev/null 2>&1
			N=$((N + 1))
			sleep 5
		done
	) &
	blog "launched merlin admin dropbear on :2222 (dropbear -p 2222 -j -k, /etc/dropbear hostkeys -> /jffs/.ssh)"

	# ★v13 INSTRUMENT (b) — FIXED★ — a SECOND debug dropbear on port :2229 to capture
	# the EXACT auth decision/reason for a rejected key — e.g. dropbear's
	#   "<path> must be owned by user or root, and not writable by group or others"
	# (the checkfileperm() rejection) or "Pubkey auth succeeded" — redirected to
	# PERSISTENT /data/dropbear-auth.log (survives the dead-man revert).
	# ★v12 BUG FIXED★: v12 launched this as `dropbear -E -F -v ...`, but `-v` is NOT a
	# valid flag on dropbear v2025.88 — it printed the usage text and EXITED, so :2229
	# never bound and NO auth verdict was ever captured. v13 DROPS -v entirely and
	# launches the documented form `dropbear -E -F -p 2229`:
	#   -E : ★REQUIRED★ — log to STDERR instead of syslog. Per the merlin dropbear src
	#        (svr-session.c svr_dropbear_log) the pubkey-auth verdict / perm-rejection
	#        line reaches stderr ONLY when !usingsyslog (=-E) — this is what surfaces
	#        "pubkey auth succeeded/failed for admin" / "bad owner or permissions on
	#        /tmp/home/root/.ssh" into our redirected log.
	#   -F : foreground (don't fork) so the redirected stderr IS this process's stderr.
	#   -j -k : same forward-disable as :2222. Same auth chain (same ~/.ssh/
	#        authorized_keys + /etc/dropbear hostkeys) so it reproduces :2222's verdict.
	# Capped babysitter (backgrounded subshell -> never blocks boot); only relaunches
	# while :2229 is unbound. The log carries auth DECISIONS only (file paths/perm
	# verdicts), NEVER key bytes.
	local dpidf=/tmp/dropbear-2229.pid
	(
		N=0
		while [ "$N" -lt 20 ]; do
			netstat -ltn 2>/dev/null | grep -q ":2229 " && break
			"$dbin" -E -F -p 2229 -j -k -P "$dpidf" >> /data/dropbear-auth.log 2>&1
			N=$((N + 1))
			sleep 5
		done
	) &
	blog "launched debug dropbear on :2229 (-E -F -p 2229, auth verdicts -> /data/dropbear-auth.log)"
}

start() {
	blog "START"

	# 1. HW switch + ext-WAN port programming (in-proc rc applets; graft-safe).
	ebegin "HW switch programming (rc config_switch)"
	rc config_switch >> /data/openrc-boot.log 2>&1
	eend $?
	ebegin "Ext-WAN port config (rc config_extwan)"
	rc config_extwan >> /data/openrc-boot.log 2>&1
	eend $?

	# 2. Open start_lan stand-in: br0 + lan_ifnames members + management IP.
	#    ★v8★: bridge AND every member brought up with ALLMULTI (IFF_ALLMULTI) —
	#    rc start_lan uses ifconfig(lan_ifname, IFUP|IFF_ALLMULTI, ...) and the
	#    members run ALLMULTI too (live br-0045: ifconfig br0/eth0 show ALLMULTI).
	#    The bcm_enet+runner datapath needs ALLMULTI to flood/forward to the CPU
	#    port; plain `ip link set up` (v7) left the runner with no CPU bridging.
	local br="br0" ifs ip nm cidr i
	ifs=$(nvram get lan_ifnames 2>/dev/null)
	ip=$(nvram get lan_ipaddr 2>/dev/null);  [ -n "$ip" ] || ip=10.0.0.8
	nm=$(nvram get lan_netmask 2>/dev/null); [ -n "$nm" ] || nm=255.255.255.0
	cidr=$(nm2cidr "$nm")
	blog "lan_ifnames='$ifs' lan_ipaddr=$ip lan_netmask=$nm (/$cidr)"
	ebegin "Bringing up $br ($ifs) -> $ip/$cidr (ALLMULTI)"
	if ! brctl show 2>/dev/null | grep -q "^${br}[[:space:]]"; then
		brctl addbr "$br" 2>/dev/null && blog "created bridge $br"
	fi
	# ★v18★ RAW eth bridging restored (v17 VOPI didn't fix inbound -> revert to the
	# br-0050-faithful raw path for a clean diagnostic). The layered iptables counters
	# (raw PREROUTING + INPUT for :2230, set up after the IP is up) + syn_probe will
	# pinpoint WHERE the SYN dies: raw-PREROUTING count 0 = never reaches the CPU
	# (runner/switch); >0 but INPUT 0 = CPU-side routing/local-delivery.
	for i in $ifs; do
		[ "$i" = "$br" ] && continue
		# member UP + ALLMULTI (ifconfig sets IFF_ALLMULTI; ip-link fallback)
		ifconfig "$i" up allmulti 2>/dev/null \
			|| { ip link set "$i" up 2>/dev/null; ip link set "$i" allmulticast on 2>/dev/null; }
		brctl addif "$br" "$i" 2>/dev/null && blog "added $i to $br (allmulti)"
	done
	# bring the bridge UP with the management IP AND ALLMULTI in one ifconfig —
	# this mirrors rc start_lan's ifconfig(lan_ifname, IFUP|IFF_ALLMULTI, ip, nm).
	ifconfig "$br" "$ip" netmask "$nm" up allmulti 2>/dev/null \
		|| { ip link set "$br" up 2>/dev/null
		     ip link set "$br" allmulticast on 2>/dev/null
		     ip addr add "$ip/$cidr" dev "$br" 2>/dev/null; }
	eend 0
	blog "bridge $br up (ALLMULTI) with $ip/$cidr"

	# ★★★ v21 THE LIKELY FIX — DEFAULT ROUTE ★★★
	# v20 instrumentation was decisive: the inbound SYN reaches the L3 INPUT hook
	# (counted 87) but NEVER reaches dropbear (0 SYN_RECV, 0 conntrack, dropbear -E log
	# empty, 0 SYN-ACK). And `ip route get 10.0.50.177` on the open-init returned
	# NOTHING — the open-init has NO DEFAULT ROUTE (net-lan set the br0 IP but never the
	# gateway; the working br-0045 has `default via 10.0.0.254 dev br0`). My build host
	# is on a DIFFERENT subnet (10.0.50.177), so the SYN-ACK return path must go via the
	# default gateway. With no route to the source, the bcm stack/blog can't build the
	# locally-terminated return flow and DROPS the inbound SYN after the netfilter hook,
	# before the socket. (The "outbound works" earlier was only SAME-subnet pings to
	# 10.0.0.x — never a routed/return path.) FIX: add the default route from nvram
	# lan_gateway, exactly as rc does. This also lets the open-init reach other subnets.
	gw=$(nvram get lan_gateway 2>/dev/null); [ -n "$gw" ] || gw=10.0.0.254
	if ip route replace default via "$gw" dev "$br" 2>/dev/null; then
		blog "v21 default route -> $gw dev $br (return path for cross-subnet inbound)"
	elif route add default gw "$gw" dev "$br" 2>/dev/null; then
		blog "v21 default route (route cmd) -> $gw dev $br"
	else
		blog "v21 WARN could not set default route via $gw"
	fi

	# 3. ★v8 Broadcom runner datapath★ — without these, br0+ip is logically up
	#    but the HW flow-accelerator never bridges eth<->br0<->CPU (the v7 gap).
	#    (a) fc enable: rc start_lan fc_init() -> `fc enable` (flow cache HW accel,
	#        AP/bridge mode, fc_disable=0). `fc` is /bin/fc -> fcctl on the device.
	#    (b) rtpolicy auto ALL: rc init_main START state (init.c:26613) -> applies
	#        the runner runtime policy from /etc/rt_policy_info.d/.
	# ★v15 ★SOFTWARE-BRIDGE DATAPATH (force net->CPU punt)★ — v14 PROVED inbound is
	# broken: the open-init listens on :2230 (unique port) + OUTBOUND works (ping
	# gateway PASS = runner fast-paths the echo-REPLY of a device-initiated flow back
	# to the CPU), but a brand-new EXTERNALLY-initiated SYN to br0's own IP (:2230) is
	# NEVER punted to the CPU. That is a FLOW-MISS punting failure: the plain-brctl br0
	# is not registered with the bcm runner/rdpa as a locally-terminating bridge whose
	# unknown-unicast misses go to the CPU. fc enable/disable does NOT change this (a
	# miss already bypasses the cache); the working bridges br20-70 get it via a
	# vlanctl VOPI rx-rule. The reliable, low-risk lever is to BYPASS the runner for
	# L2 forwarding entirely: `ethswctl -c hw-switching -o disable` makes the HW switch
	# deliver ALL frames to the CPU port, so the Linux bridge (br0) does the forwarding
	# in software and EVERY inbound packet (incl. new SYNs) reaches the CPU. Slower (no
	# HW offload) but REACHABLE — exactly the handoff's #1 plan. We also `fc disable`
	# and skip `rtpolicy auto ALL` so no fast-path competes. (If this proves inbound,
	# v16 can restore HW offload with a proper per-br0 vlanctl CPU-punt rule.)
	# ★v16 DATAPATH = faithful baseline (fc enable + rtpolicy)★ — v15's
	# `ethswctl hw-switching disable` FAILED (rc=95, unsupported at runtime) so it was
	# a no-op; revert to the v14 datapath that DOES get br0 receiving frames (v15
	# net-diag /proc/net/dev: br0 RX 60 pkts/3192 B incl 25 mcast — inbound L2 DOES
	# reach the CPU). v16 is a DIAGNOSTIC trial: keep this datapath and add a SYN-probe
	# (see syn_probe below) to settle whether my unicast SYN to :2230 actually reaches
	# dropbear (-> return-path issue) or never arrives (-> runner punt issue).
	ebegin "Broadcom datapath: fc enable + rtpolicy auto ALL (faithful baseline)"
	if [ "$(nvram get fc_disable 2>/dev/null)" != "1" ]; then
		fc enable >> /data/openrc-boot.log 2>&1 && blog "fc enable (flow cache HW accel)"
	else
		blog "fc_disable=1 -> skip fc enable"
	fi
	if [ "$(nvram get runner_disable 2>/dev/null)" != "1" ]; then
		rtpolicy auto ALL >> /data/openrc-boot.log 2>&1 && blog "rtpolicy auto ALL (runner policy)"
	else
		blog "runner_disable=1 -> skip rtpolicy"
	fi
	eend 0
	blog "datapath configured — eth <-> $br <-> CPU should pass traffic"

	# 4. sshd reachability: :2223 rescue (defensive; rc3.d may already have it) +
	#    ★v10★ :2222 admin = faithful merlin replica (/jffs hostkeys + nvram authkeys
	#    + EXACT `dropbear -p 2222 -j -k` cmdline) so the open-init is reachable with
	#    the SAME admin key as br-0045. (v9 used a keyless /data-hostkey dropbear that
	#    never bound — see start_admin_dropbear header.)
	ebegin "Starting sshd (:2223 rescue + :2222 admin merlin replica + :2230 SLOT-PROOF)"
	start_dropbear 2223 /usr/br/sbin/dropbearmulti
	start_admin_dropbear
	# ★v14 ★UNAMBIGUOUS INBOUND / SLOT PROOF★ — a dropbear on the UNIQUE port :2230
	# that NEITHER br-0045 NOR br-0050 ever opens. The whole v2..v13 saga was
	# ambiguous about whether the open-init (slot2) was EVER reachable inbound: every
	# port answering on 10.0.0.8 (:2222/:80/:2223) ALSO exists on br-0045/br-0050, so a
	# catcher could not tell "open-init reachable" from "br-0045 after the auto-revert".
	# :2230 is opened ONLY by this open-init. So:
	#   * `nc 10.0.0.8 2230` returns the SSH-2.0 banner  ==> INBOUND WORKS on slot2
	#     (the bcm datapath punts net->CPU) — definitive, slot-unambiguous, NO auth needed.
	#   * `ssh -p 2230 admin@10.0.0.8` logs in            ==> AUTH also works.
	# This cleanly SEPARATES the two open questions (inbound datapath vs key-auth) that
	# were conflated before, WITHOUT changing the v13 datapath (so the result is a clean
	# read on whether v13's fc-enable datapath already gives inbound). Same `-j -k`
	# default-hostkey + ~/.ssh/authorized_keys auth chain that start_admin_dropbear just
	# set up (so :2230 auth == :2222 auth). Capped babysitter; only relaunches while
	# :2230 is unbound; can NEVER wedge boot.
	(
		dbin=/usr/sbin/dropbear; N=0
		[ -x "$dbin" ] || dbin=/usr/br/sbin/dropbearmulti
		while [ "$N" -lt 20 ]; do
			netstat -ltn 2>/dev/null | grep -q ":2230 " && break
			# ★v22★ plain self-backgrounding (no -E -F logging — that grew /data on a
			# committed baseline). Trial-only -E logging is gated below on .trial-armed.
			if [ -f /data/.trial-armed ]; then
				"$dbin" -E -F -p 2230 -j -k >> /data/dropbear-2230.log 2>&1
			else
				"$dbin" -p 2230 -j -k -P /tmp/dropbear-2230.pid >/dev/null 2>&1
			fi
			N=$((N + 1))
			sleep 5
		done
	) &
	blog "launched SLOT-PROOF dropbear on :2230 (trial: -E log; committed: plain)"
	eend 0

	blog "DONE — datapath up; open-init reachable on :2222 (+ :2223 rescue, :2230 slot-proof) at $ip"

	# 5. ★v9 SELF-DIAGNOSTICS★ — v8 ran every datapath step + dropbear "listening"
	#    yet NO traffic passed on :2222/:2223, and live debug is impossible (the
	#    image runs unattended on the trial, then the dead-man reverts). So the
	#    image must SELF-REPORT: dump the full network + Broadcom-datapath state
	#    and a connectivity self-test to PERSISTENT /data/net-diag.log (survives
	#    the revert). Backgrounded + every probe time-bounded so it can NEVER hang
	#    the boot. The next trial's /data/net-diag.log then says whether the
	#    datapath passes traffic (gateway ping) and whether sshd actually listens.
	# ★★★ v19 THE FIX — open the INPUT firewall ★★★
	# v18 PROVED it: raw/PREROUTING :2230 = 87 pkts AND INPUT :2230 = 87 pkts, yet
	# dropbear saw 0 SYN_RECV. The SYN reaches the CPU and the local INPUT chain, then a
	# LATER INPUT rule (or a DROP policy) drops it before the socket. It was NEVER the
	# Broadcom runner (all of v14-v17 chased the wrong layer) — it is a plain Linux
	# iptables firewall the graft leaves default-deny for NEW inbound (ESTABLISHED/
	# RELATED replies pass, which is why ping/ARP/outbound worked). The full ASUS rc
	# opens this; the open-init never did. FIX: record the original rules (so we know
	# exactly what dropped it), then set ACCEPT policy + flush INPUT so NEW inbound to
	# our mgmt ports reaches the sockets. (Trial-wide open; once reachable+committed a
	# v20 can narrow it to the mgmt ports only.)
	{
		echo "==== v19 FIREWALL BEFORE (uptime $(cat /proc/uptime 2>/dev/null)) ===="
		echo "--- iptables -S ---";        iptables -S 2>&1
		echo "--- iptables -L INPUT -vn ---"; iptables -L INPUT -vn 2>&1
		echo "--- ip6tables -S (INPUT) ---";  ip6tables -S 2>&1 | grep -i input
	} >> /data/firewall.log 2>&1
	for t in INPUT FORWARD OUTPUT; do iptables -P "$t" ACCEPT 2>/dev/null; ip6tables -P "$t" ACCEPT 2>/dev/null; done
	iptables -F INPUT 2>/dev/null && blog "v19 INPUT chain FLUSHED + policy ACCEPT (open inbound)"
	iptables -t raw -F PREROUTING 2>/dev/null
	{
		echo "==== v19 FIREWALL AFTER flush+accept ===="
		iptables -S 2>&1
	} >> /data/firewall.log 2>&1

	# ★v18 LAYERED SYN COUNTERS★ — insert counting rules at the two earliest CPU
	# netfilter hooks for dport 2230 (nothing else hits :2230, so the counts are PURELY
	# my external SYNs): raw/PREROUTING = the packet was delivered to the CPU at all;
	# INPUT = it passed routing as locally-destined. After the trial: raw-PREROUTING 0
	# => the SYN never reaches the CPU (runner/switch drop); raw>0 & INPUT 0 => CPU got
	# it but routing didn't deliver locally; both>0 => reaches dropbear (return-path).
	# -I inserts at the top so other rules can't mask the count; no -j => count-only.
	iptables -t raw -I PREROUTING -p tcp --dport 2230 >> /data/openrc-boot.log 2>&1 \
		&& blog "v18 raw/PREROUTING :2230 counter armed" \
		|| blog "v18 WARN raw/PREROUTING counter failed"
	iptables -I INPUT -p tcp --dport 2230 >> /data/openrc-boot.log 2>&1 \
		&& blog "v18 INPUT :2230 counter armed" \
		|| blog "v18 WARN INPUT counter failed"
	# ★v20★ OUTPUT --sport 2230 counter: did dropbear actually SEND a SYN-ACK? If >0,
	# the SYN reached dropbear (=> RETURN-PATH issue); if 0, the SYN dies between the
	# INPUT hook and the socket (bridge-nf / blog accelerator consumes it).
	iptables -I OUTPUT -p tcp --sport 2230 >> /data/openrc-boot.log 2>&1 \
		&& blog "v20 OUTPUT :2230 (SYN-ACK) counter armed" || blog "v20 WARN OUTPUT counter failed"
	# ★v20★ one-time L2/bridge-nf state dump (does br0 own its MAC locally? is
	# bridge-nf-call-iptables intercepting? what's the return route?).
	{
		echo "==== v20 L2/bridge-nf state (uptime $(cat /proc/uptime 2>/dev/null)) ===="
		echo "--- bridge-nf sysctls ---"
		for s in bridge-nf-call-iptables bridge-nf-call-ip6tables bridge-nf-filter-vlan-tagged; do
			echo "$s = $(cat /proc/sys/net/bridge/$s 2>/dev/null)"
		done
		echo "rp_filter br0 = $(cat /proc/sys/net/ipv4/conf/br0/rp_filter 2>/dev/null); all = $(cat /proc/sys/net/ipv4/conf/all/rp_filter 2>/dev/null)"
		echo "--- brctl showmacs br0 (is_local for br0 MAC?) ---"
		brctl showmacs br0 2>/dev/null | grep -iE 'mac addr|yes' | head
		echo "--- ip route get 10.0.50.177 (return path to build host) ---"
		ip route get 10.0.50.177 2>/dev/null
		echo "--- ip route get 10.0.40.3 ---"
		ip route get 10.0.40.3 2>/dev/null
	} >> /data/firewall.log 2>&1

	# ★v22★ Heavy diagnostics run ONLY on a TRIAL boot (.trial-armed): net-diag
	# (~45KB/boot) + syn_probe (~21KB/boot) would slowly grow /data on a committed
	# baseline — which is unnecessary now that the device is reachable + debuggable live.
	# (Auto-disarm-on-inbound stays REMOVED — operator: disarm only from an SSH session.)
	if [ -f /data/.trial-armed ]; then
		run_diagnostics "$br" "$ip" &
		syn_probe &
		blog "v22 TRIAL diagnostics: run_diagnostics + syn_probe launched"
	else
		blog "v22 COMMITTED boot — heavy diagnostics skipped (clean)"
	fi

	return 0
}

# ★v16★ Append the FULL (not -l) tcp socket table filtered to our probe ports every
# 3s for ~200s to /data/syn-probe.log. This reveals SYN_RECV (the SYN reached the CPU
# + dropbear replied SYN-ACK but the handshake didn't complete -> RETURN-PATH issue)
# vs ESTABLISHED (full inbound works) vs nothing-but-LISTEN (the SYN never reached the
# CPU -> runner punt issue). Bounded; never blocks boot. No keys/MACs.
syn_probe() {
	local i=0
	echo "==== v16 SYN-PROBE start uptime=$(cat /proc/uptime 2>/dev/null) ====" >> /data/syn-probe.log 2>&1
	while [ "$i" -lt 65 ]; do
		{
			echo "--- t=$i uptime=$(cat /proc/uptime 2>/dev/null | cut -d' ' -f1) ---"
			netstat -tn 2>/dev/null | awk 'NR<=2 || $4 ~ /:(2230|2222|80)$/ {print}'
			# ★v18★ layered SYN counters (pkts that reached each CPU hook)
			echo "[raw/PRE :2230] $(iptables -t raw -L PREROUTING -vnx 2>/dev/null | awk '/dpt:2230/{print $1" pkts"}')"
			echo "[INPUT  :2230] $(iptables -L INPUT -vnx 2>/dev/null | awk '/dpt:2230/{print $1" pkts"}')"
			echo "[OUTPUT :2230] $(iptables -L OUTPUT -vnx 2>/dev/null | awk '/spt:2230/{print $1" pkts(synack)"}')"
			echo "[conntrack] $(conntrack -L 2>/dev/null | grep -c 2230) :2230 entries"
			conntrack -L 2>/dev/null | grep 2230 | head -2
		} >> /data/syn-probe.log 2>&1
		i=$((i + 1))
		sleep 3
	done
	echo "==== v16 SYN-PROBE end ====" >> /data/syn-probe.log 2>&1
}

# === v9 self-diagnostics ====================================================
# Append the live network + datapath + listener + connectivity state to a
# PERSISTENT log. PRIVACY: never log keys/MACs — every dump is piped through
# redact_mac (xx:xx:xx:xx:xx:xx) and we never touch the dropbear hostkey/
# fingerprint. Each command is guarded `2>&1`, skipped if its binary is absent,
# and time-bounded (run_to) so a stuck tool cannot wedge the diagnostics.
DIAG=/data/net-diag.log

# redact every MAC (and bare 6-octet hwaddr) so net-diag.log carries no MACs.
redact_mac() {
	sed -E 's/([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}/xx:xx:xx:xx:xx:xx/g'
}

# run_to SECS CMD... — run a command bounded by `timeout` (busybox has it);
# falls back to a background kill if timeout is unavailable. Output is appended
# (already redacted by the caller's pipeline).
run_to() {
	local s="$1"; shift
	if command -v timeout >/dev/null 2>&1; then
		timeout "$s" "$@" 2>&1
	else
		( "$@" 2>&1 ) & local p=$!
		( sleep "$s"; kill "$p" 2>/dev/null ) & local k=$!
		wait "$p" 2>/dev/null; kill "$k" 2>/dev/null
	fi
}

# diag SECS "LABEL" CMD... — emit a labeled section iff CMD's binary exists,
# redacting MACs. Skips (with a note) if the binary is missing.
diag() {
	local s="$1" label="$2"; shift 2
	{
		echo "----- $label -----"
		if command -v "$1" >/dev/null 2>&1; then
			run_to "$s" "$@" | redact_mac
		else
			echo "(skip: $1 not present)"
		fi
		echo
	} >> "$DIAG" 2>/dev/null
}

# ping_test LABEL TARGET — ping with a clear PASS/FAIL line (the key datapath
# probe). 3 echo requests, 2s per-packet wait, whole thing bounded to 12s.
ping_test() {
	local label="$1" tgt="$2" out rc
	{
		echo "----- PING $label ($tgt) -----"
		if [ -z "$tgt" ]; then
			echo "RESULT: SKIP $label — no target"
			echo; return
		fi
		if ! command -v ping >/dev/null 2>&1; then
			echo "RESULT: SKIP $label — ping not present"
			echo; return
		fi
		out=$(run_to 12 ping -c3 -W2 "$tgt"); rc=$?
		echo "$out" | redact_mac
		if [ "$rc" -eq 0 ] && echo "$out" | grep -q ' 0% packet loss'; then
			echo "RESULT: PASS $label ($tgt) reachable"
		else
			echo "RESULT: FAIL $label ($tgt) UNREACHABLE (rc=$rc)"
		fi
		echo
	} >> "$DIAG" 2>/dev/null
}

run_diagnostics() {
	local br="$1" ip="$2" gw
	gw=$(nvram get lan_gateway 2>/dev/null)
	{
		echo "================================================================"
		echo "GT-BE98 open-init-v9 net-lan SELF-DIAGNOSTICS"
		echo "uptime: $(cat /proc/uptime 2>/dev/null)"
		echo "date:   $(date 2>/dev/null)"
		echo "br=$br ip=$ip lan_gateway=${gw:-<unset>}"
		echo "================================================================"
	} >> "$DIAG" 2>/dev/null

	# --- L2/L3 network state (MACs redacted) ---
	diag 5  "ip -d addr show"        ip -d addr show
	diag 5  "ip route show"          ip route show
	diag 5  "ip neigh"               ip neigh
	diag 5  "arp -an"                arp -an
	diag 5  "brctl show"             brctl show
	diag 5  "brctl showmacs $br"     brctl showmacs "$br"
	diag 5  "/proc/net/dev"          cat /proc/net/dev

	# --- Broadcom switch / runner / flow-accelerator datapath state ---
	# ethswctl/ethctl: link + port state for eth0 (the LAN uplink to the switch).
	diag 5  "ethswctl mode (getifname unit0 port0)" ethswctl getifname 0 0
	diag 5  "ethctl eth0 media-type"  ethctl eth0 media-type
	diag 5  "ethctl eth0 phy-power"   ethctl eth0 phy-power
	diag 5  "vlanctl --dump-table"    vlanctl --dump-table
	diag 5  "fcctl status"            fcctl status
	# rtpolicy has no 'show' subcmd; the applied runner policy lives in this dir.
	diag 5  "rtpolicy config dir (/etc/rt_policy_info.d)" ls -la /etc/rt_policy_info.d
	# loaded runner/flow modules (datapath drivers) — confirms the HW path exists.
	diag 5  "loaded runner/flow modules" sh -c 'grep -E "pktrunner|pktflow|bcm_enet|cmdlist|rdpa|bdmf|archer" /proc/modules'
	diag 5  "/proc/driver/enet listing" ls -la /proc/driver/enet

	# --- ★listening sockets: confirm dropbear is REALLY listening :2222+:2223★ ---
	{
		echo "----- LISTENING TCP SOCKETS (netstat -ltn || ss -ltn) -----"
		if command -v netstat >/dev/null 2>&1; then
			run_to 5 netstat -ltn | redact_mac
		elif command -v ss >/dev/null 2>&1; then
			run_to 5 ss -ltn | redact_mac
		else
			echo "(skip: neither netstat nor ss present)"
		fi
		echo
		# explicit per-port verdict for the two dropbear listeners
		for p in 2222 2223; do
			if { netstat -ltn 2>/dev/null || ss -ltn 2>/dev/null; } | grep -q ":${p} "; then
				echo "RESULT: PASS sshd LISTENING on :$p"
			else
				echo "RESULT: FAIL sshd NOT listening on :$p"
			fi
		done
		echo
	} >> "$DIAG" 2>/dev/null

	# --- ★CONNECTIVITY SELF-TEST (the key datapath probe)★ ---
	ping_test "loopback"        127.0.0.1
	ping_test "gateway-10.0.0.1" 10.0.0.1
	ping_test "nvram-lan_gateway" "$gw"

	echo "===== net-diag complete =====" >> "$DIAG" 2>/dev/null
	blog "self-diagnostics written to $DIAG"
}
