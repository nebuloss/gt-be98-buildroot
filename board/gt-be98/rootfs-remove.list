# M4 cumulative removal list. The transform unpacks the pristine 0031 blob
# every build, so this list MUST accumulate across slices — a slice-only list
# silently re-adds earlier removals (caught by rootfs-diff on the first
# br-0036 build, 2026-06-06). One NEW slice (≤5 removals) per trial.

# --- slice 1 (br-0035, ADOPTED 2026-06-06, gate 20/20) ---
# telemetry/cloud/phone-home + wsdd2
/usr/sbin/infosvr
/usr/sbin/awsiot
/usr/sbin/mastiff
/usr/bin/asd
/usr/sbin/wsdd2

# --- slice 2 (br-0036, this trial) ---
# networkmap LAN scanner (+ its data dir) and uamsrv (captive-portal
# lighttpd symlink). Live pre-check 2026-06-06: neither running.
/usr/sbin/networkmap
/usr/networkmap
/usr/sbin/uamsrv

# --- slice 3 (br-0037, TRIAL PENDING - built+diff-proven 2026-06-06,
# flash deferred: daily trial budget exhausted) ---
# AiMesh/cfg ecosystem core daemons; starters nvram-gated (patches 0027-0029)
/usr/sbin/cfg_server
/usr/sbin/wlc_nt
/usr/sbin/lldpd

# --- slice 4 (br-0038) ---
# AiMesh rc-multicall symlinks (all -> rc, none running on br-0037; starters
# re_mode/nvram-gated). The rc binary itself is untouched.
/sbin/amas_lanctrl
/sbin/amas_portstatus
/sbin/amas_ssd_cd
/sbin/conn_diag

# --- slice 5 (br-0039) ---
# band-steer / roaming assist (both off in stock; roamast is an rc symlink)
/usr/sbin/bsd
/sbin/roamast

# --- slice 6 (br-0040) ---
# re_mode-only AiMesh-node crew (all -> rc symlinks; re_mode=0 on this AP,
# none running). Completes br-0033 batch-1 parity except the banned envrams
# wrapper.
/sbin/amas_bhctrl
/sbin/amas_ssd
/sbin/amas_status
/sbin/amas_misc
/sbin/amas_wlcconnect
